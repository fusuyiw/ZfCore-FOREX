# ZF Core Scanner V20 configuration example
# Copy this file to .env, then fill values as needed.

# Data provider:
# - MT5: use local MetaTrader 5 terminal on Windows
# - YFINANCE: use Yahoo Finance data via yfinance
ZF_DATA_PROVIDER=MT5

# Optional macro/news API keys.
# Leave empty if you do not use these features.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=


# Scanner universe.
# Default target for Exness phase 1: forex + energy. Add metal later if needed.
ZF_ASSET_CLASSES=forex,energy,metal,crypto
ZF_ACTIVE_SYMBOL_LIMIT=10
ZF_USE_PRIMARY_SYMBOL_PROFILE=1
ZF_FOCUS_SYMBOLS=XAUUSDm
ZF_AUTO_HISTORICAL_VALIDATION=1
ZF_HISTORICAL_LOOKBACK_DAYS=60
ZF_HISTORICAL_REFRESH_HOURS=168
ZF_PROFILE_MIN_SIGNALS=15
ZF_DEFAULT_SCAN_TIMEFRAME=M15
# 0 = force ZF_DEFAULT_SCAN_TIMEFRAME for every active symbol.
# 1 = use best historical timeframe per symbol from validation profile.
ZF_USE_PROFILE_TIMEFRAMES=0
ZF_USE_FIBO_FILTER=1
ZF_MIN_EXECUTION_ZF_SCORE=0.50
ZF_METAL_MIN_DRIFT=1.0
ZF_METAL_REQUIRE_TREND=1
ZF_VALIDATION_ZF_FLOOR=0.50
ZF_VALIDATION_FIBO_FILTER=1
ZF_VALIDATION_TRAILING=1
ZF_VALIDATION_TIMEFRAMES=M15
ZF_VALIDATION_EXIT_MODE=dynamic_sl_tp
ZF_VALIDATION_HORIZON_BARS=96
ZF_STRICT_ACCURACY_MODE=1
ZF_STRICT_MIN_QUALITY_SCORE=55
ZF_STRICT_MIN_HISTORICAL_WIN_RATE=58
ZF_STRICT_MIN_HISTORICAL_EXPECTANCY_R=0.03
ZF_STRICT_MIN_PROJECTED_MATURITY=0.55
ZF_STRICT_MIN_PROJECTED_RR=1.15
ZF_STRICT_MIN_STRICT_RR=1.05
ZF_TP_ONLY_TARGET_PIPS=50
ZF_AUTO_EXECUTION_REQUIRES_SL=1
ZF_TP_ONLY_LIVE_HORIZON_BARS=96

# MT5 EA auto-executor bridge.
ZF_EXPORT_EA_SIGNALS=1
ZF_EA_SIGNAL_FILE_NAME=zf_ea_signals.csv
ZF_EA_SIGNAL_EXPIRE_MINUTES=240
ZF_EA_MAX_LOT=1.0
# BUY_LIMIT makes BUY signals become pending limit orders in the EA.
# SELL_LIMIT makes SELL signals become pending limit orders in the EA.
# Use BUY/SELL if you want normal market execution.
ZF_EA_BUY_ORDER_TYPE=BUY_LIMIT
ZF_EA_SELL_ORDER_TYPE=SELL_LIMIT
ZF_EA_MAGIC_NUMBER=26061620
ZF_SYNC_MT5_FORWARD_RESULTS=1
ZF_MT5_FORWARD_LOOKBACK_DAYS=30

# Public OKX derivatives context for crypto. No API key is required.
ZF_OKX_PUBLIC_DATA_ENABLED=1
ZF_OKX_BASE_URL=https://www.okx.com
ZF_OKX_TIMEOUT_SECONDS=8
ZF_OKX_CACHE_SECONDS=60
# Keep 0 so a temporary OKX outage does not stop MT5 crypto analysis.
ZF_OKX_REQUIRE_CRYPTO_DATA=0

# Fractional Kelly can only reduce the scanner's baseline risk.
ZF_FRACTIONAL_KELLY_ENABLED=1
ZF_FRACTIONAL_KELLY_FRACTION=0.25
ZF_FRACTIONAL_KELLY_MIN_MULTIPLIER=0.25

# Weekly bounded grid search. Keep trailing aligned with the live EA.
ZF_WEEKLY_GRID_OPTIMIZER_ENABLED=1
ZF_WEEKLY_ZF_FLOORS=0.45,0.50,0.55
ZF_WEEKLY_TRAILING_OPTIONS=1

# Optional MT5 symbol suffix filter.
# Leave empty to scan every MT5 symbol that matches supported asset names.
# Example: MT5_SYMBOL_SUFFIXES=.m,.pro
MT5_SYMBOL_SUFFIXES=

# Optional storage override.
# Leave empty to store archives and learning files beside the scanner script.
ZF_STORAGE_DIR=

# YFINANCE mode settings.
# Used only when ZF_DATA_PROVIDER=YFINANCE.
YFINANCE_ACCOUNT_EQUITY_FALLBACK=1000
YFINANCE_SYMBOLS=EURUSD.yf,GBPUSD.yf,AUDUSD.yf,USDJPY.yf,XAUUSD.yf

# OANDA legacy/experimental settings.
# Used only when ZF_DATA_PROVIDER=OANDA.
OANDA_ENV=practice
OANDA_ACCOUNT_ID=
OANDA_API_TOKEN=
OANDA_ACCOUNT_EQUITY_FALLBACK=1000
OANDA_SYMBOLS=
